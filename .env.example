# Password to access the app — required
AUTH_PASSWORD=changeme

# Random secret for signing session cookies — use a long random string
SESSION_SECRET=change-this-to-a-random-secret-value

# Cloudflare Tunnel token — from the Cloudflare Zero Trust dashboard
CLOUDFLARE_TUNNEL_TOKEN=

# Port to expose the frontend on (default: 80)
# PORT=80

# CORS origin allowed by the backend (leave blank in production — nginx handles same-origin)
# CORS_ORIGIN=
